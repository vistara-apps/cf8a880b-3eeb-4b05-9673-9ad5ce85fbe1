# PayChat Environment Configuration

# Coinbase OnchainKit API Key
# Get your API key from: https://portal.cdp.coinbase.com/
NEXT_PUBLIC_ONCHAINKIT_API_KEY=cdp_demo_key

# Application URL
# For development: http://localhost:3000
# For production: https://your-domain.com
NEXT_PUBLIC_URL=http://localhost:3000

# Base Network Chain ID
# Base Mainnet: 8453
# Base Sepolia (testnet): 84532
NEXT_PUBLIC_CHAIN_ID=8453

# Optional: Neynar API Key for enhanced Farcaster integration
# Get your API key from: https://neynar.com/
NEYNAR_API_KEY=NEYNAR_API_DOCS

# Optional: Database Configuration (for production)
# DATABASE_URL=postgresql://username:password@localhost:5432/paychat
# REDIS_URL=redis://localhost:6379

# Optional: Analytics and Monitoring
# VERCEL_ANALYTICS_ID=your_analytics_id
# SENTRY_DSN=your_sentry_dsn

# Optional: Rate Limiting
# UPSTASH_REDIS_REST_URL=your_upstash_url
# UPSTASH_REDIS_REST_TOKEN=your_upstash_token
